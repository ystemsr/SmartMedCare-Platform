# App
APP_NAME=SmartMedCare
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

# MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=smartmedcare
MYSQL_PASSWORD=smartmedcare123
MYSQL_DATABASE=smartmedcare

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=smartmedcare
MINIO_SECURE=false

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Big Data - HDFS / Hive / Spark
HDFS_NAMENODE_URL=http://hadoop-namenode:9870
HDFS_NAMENODE_RPC=hdfs://hadoop-namenode:9000
HIVE_HOST=hive-server
HIVE_PORT=10000
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_IMAGE=smartmedcare-spark-apps:local
SPARK_CONTAINER=smartmedcare-spark-master
HIVE_METASTORE_DB_USER=hive
HIVE_METASTORE_DB_PASSWORD=hive123

# ML model
ML_MODEL_PATH=/app/models/multitask_health_model.pt
SPARK_LOG_DIR=/app/logs/spark

# Weather API
WEATHER_API_KEY=your_openweathermap_api_key

# Big Data pipeline auto-run (bootstrap only; admin UI overrides these)
# When enabled, the backend triggers the full 3-stage pipeline every day
# at PIPELINE_SCHEDULE_UTC_TIME (HH:MM, 24h, UTC).
# 19:00 UTC = 03:00 Asia/Shanghai.
PIPELINE_SCHEDULE_ENABLED=true
PIPELINE_SCHEDULE_UTC_TIME=19:00

# AI 助手 (OpenAI-compatible; defaults target OpenRouter)
# These bootstrap the AI config on first boot; admins can override them
# from the platform's "AI 模型配置" tab, which persists to system_configs.
AI_API_KEY=your_api_key
AI_BASE_URL=https://openrouter.ai/api/v1