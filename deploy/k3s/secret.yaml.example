# Template for backend Secret. scripts/k3s-up.sh renders the real
# version from the project's .env at deploy time. Do NOT commit a
# filled-in copy of this file.
apiVersion: v1
kind: Secret
metadata:
  name: backend-secret
  namespace: smartmedcare
type: Opaque
stringData:
  SECRET_KEY: "__SECRET_KEY__"
  MYSQL_USER: "__MYSQL_USER__"
  MYSQL_PASSWORD: "__MYSQL_PASSWORD__"
  MINIO_ACCESS_KEY: "__MINIO_ACCESS_KEY__"
  MINIO_SECRET_KEY: "__MINIO_SECRET_KEY__"
  HIVE_METASTORE_DB_PASSWORD: "__HIVE_METASTORE_DB_PASSWORD__"
  WEATHER_API_KEY: "__WEATHER_API_KEY__"
  AI_API_KEY: "__AI_API_KEY__"
  BRAVE_API_KEY: "__BRAVE_API_KEY__"
  QDRANT_API_KEY: "__QDRANT_API_KEY__"
  KB_EMBEDDING_API_KEY: "__KB_EMBEDDING_API_KEY__"
